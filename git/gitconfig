[user]
    # No default — forces per-directory configuration via includeIf

[gpg]
    format = ssh

[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
    allowedSignersFile =

[commit]
    gpgSign = true

[tag]
    gpgsign = true

[includeIf "gitdir:~/Workspace/personal/"]
    path = ~/.gitconfig-personal

[includeIf "gitdir:~/Workspace/starlight/"]
    path = ~/.gitconfig-work
