#!/usr/bin/env bash
# kwin-mcp-run: wrapper that runs kwin-mcp and kills orphaned virtual sessions on exit.
# Usage:
#   echo '<jsonrpc payload>' | kwin-mcp-run
#   kwin-mcp-run <args>

set -u

KWIN_PYTHON="${KWIN_MCP_PYTHON:-$HOME/.local/share/uv/tools/kwin-mcp/bin/python}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}"

if [[ ! -x "$KWIN_PYTHON" ]]; then
  echo "kwin-mcp python runtime not found at: $KWIN_PYTHON" >&2
  echo "Install first: uv tool install kwin-mcp --python /usr/bin/python3" >&2
  exit 1
fi

"$KWIN_PYTHON" -c '
import sys
sys.argv = ["kwin-mcp", *sys.argv[1:]]
from kwin_mcp.server import main
main()
' "$@"
RC=$?

sleep 1
pkill -f "kwin_wayland --virtual --no-lockscreen" 2>/dev/null || true
pkill -f "wayland-mcp-[0-9]+-[0-9]+" 2>/dev/null || true

exit $RC
